# Database
DATABASE_URL=postgres://belastingdinst:changeme@localhost:5432/belastingdinst

# Auth
NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32
NEXTAUTH_URL=http://localhost:3000

# Encryption key for Ponto tokens at rest (AES-256-GCM: 32 bytes hex)
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# Ponto / Isabel Connect (Phase 9 - optional)
PONTO_CLIENT_ID=
PONTO_CLIENT_SECRET=
PONTO_SANDBOX=true

# Phase 10: Digipoort (out of scope v1)
# PKIOVERHEID_CERT_PATH=/run/secrets/pkioverheid.crt
# PKIOVERHEID_KEY_PATH=/run/secrets/pkioverheid.key
